{
  "manifest_version": 3,
  "name": "PromptProtect",
  "version": "0.1.0",
  "description": "Blocks accidental secrets and PII from being sent to ChatGPT, Claude, and Gemini.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background/index.js"
  },
  "action": {
    "default_title": "Open PromptProtect"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ]
}

