{
  "manifest_version": 3,
  "name": "PromptProtect",
  "version": "0.1.0",
  "description": "Blocks accidental secrets and PII from being sent to ChatGPT, Claude, and Gemini.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "tabs", "sidePanel"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background/index.js"
  },
  "icons": {
    "16": "icons/shield-16.png",
    "32": "icons/shield-32.png",
    "48": "icons/shield-48.png",
    "128": "icons/shield-128.png"
  },
  "action": {
    "default_title": "Open PromptProtect",
    "default_icon": {
      "16": "icons/shield-16.png",
      "32": "icons/shield-32.png",
      "48": "icons/shield-48.png",
      "128": "icons/shield-128.png"
    }
  },
  "sidebar_action": {
    "default_icon": {
      "19": "icons/shield-19.png",
      "38": "icons/shield-38.png"
    },
    "default_title": "PromptProtect",
    "default_panel": "sidepanel.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ]
}
